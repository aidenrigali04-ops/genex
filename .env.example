# Supabase (https://supabase.com/dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional: server-only. Used for /api/video-jobs uploads to avoid storage.buckets RLS false "Bucket not found".
SUPABASE_SERVICE_ROLE_KEY=

# Optional: signed playback URLs for completed video variations (seconds, default 7200, max 604800).
# VIDEO_SIGNED_URL_SECONDS=7200

# OpenAI (https://platform.openai.com/api-keys) — used by /api/generate, /api/chat, file transcription
OPENAI_API_KEY=

# Stage 2 text→video worker (Pexels + ElevenLabs + ffmpeg). Set on Next + worker service.
# PEXELS_API_KEY=                  # https://www.pexels.com/api/
# ELEVENLABS_API_KEY=              # https://elevenlabs.io
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# TEXT_VIDEO_CREDIT_COST=5

# Testing: unlimited daily credits (server skips consume_one_credit). Do not set in production.
GENEX_UNLIMITED_CREDITS=0
# Same for guest UI + localStorage (rebuild after changing)
NEXT_PUBLIC_GENEX_UNLIMITED_CREDITS=0

# Production base URL (OAuth return_to, cookies). In Vercel: Project → Settings → Environment Variables
# Use your deployment URL, e.g. https://genex-xxx.vercel.app (no trailing slash)
NEXT_PUBLIC_SITE_URL=
