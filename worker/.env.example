# Copy from ../.env.local for local dev, or set these in Railway / your host.
# `npm run worker` loads ../.env.local after worker/.env (PEXELS, ElevenLabs, etc.).

# Same Supabase project as the Next app (either is fine)
SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_URL=

SUPABASE_SERVICE_ROLE_KEY=
OPENAI_API_KEY=

# Stage 2 text→video worker (`node text-video-worker.js`)
PEXELS_API_KEY=
# Free tier often returns 401 from cloud IPs (Railway, VPN). Use a paid plan for production workers.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# Optional; stream endpoint uses this as query param (default mp3_44100_128)
# ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
TEXT_VIDEO_CREDIT_COST=5

# Optional: mix a royalty-free bed under each rendered variation (local path inside the worker container).
# GENEX_BGM_LOCAL_PATH=/app/assets/bed.mp3
# GENEX_BGM_VOLUME=0.22

# Optional: caption font for FFmpeg drawtext (Arabic-capable TTF if you serve Arabic overlays).
# GENEX_CAPTION_FONT_ARABIC=/usr/share/fonts/truetype/noto/NotoNaskhArabic-Regular.ttf

# Options: default | top | large | minimal
GENEX_CAPTION_STYLE=default
