# Supabase (https://supabase.com/dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional: server-only. Used for /api/video-jobs uploads to avoid storage.buckets RLS false "Bucket not found".
SUPABASE_SERVICE_ROLE_KEY=

# Optional: signed playback URLs for completed video variations (seconds, default 7200, max 604800).
# VIDEO_SIGNED_URL_SECONDS=7200

# OpenAI (https://platform.openai.com/api-keys) — used by /api/generate, /api/chat, file transcription
OPENAI_API_KEY=

# ENABLE_TEXT_VIDEO_JOBS=0  # optional: disable stock-from-script jobs (API + worker poller)
#
# Credits: source clipping (`video_jobs`, /api/video-jobs) defaults to 3 per job (see lib/video-job-cost.ts).
# Stock-from-script (`text_video_jobs`) uses TEXT_VIDEO_CREDIT_COST (default 5).
#
# Stage 2 text→video worker (Pexels + ElevenLabs + ffmpeg). The Node worker loads worker/.env
# then finds the app root (folder with package.json name "genex") for .env / .env.local.
# Production: set PEXELS_API_KEY on the worker service; .env.local is not shipped in Docker.
# GENEX_APP_ROOT=/path/to/genex  # optional if auto-discovery fails
# PEXELS_API_KEY=                  # https://www.pexels.com/api/
# Aliases (same value): PEXELS_ACCESS_TOKEN, PEXEL_API_KEY, PEXELS_KEY
# ELEVENLABS_API_KEY=              # https://elevenlabs.io
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# TEXT_VIDEO_CREDIT_COST=5

# Testing: unlimited daily credits (server skips consume_one_credit). Do not set in production.
GENEX_UNLIMITED_CREDITS=0
# Same for guest UI + localStorage (rebuild after changing)
NEXT_PUBLIC_GENEX_UNLIMITED_CREDITS=0

# Production base URL (OAuth return_to, cookies). In Vercel: Project → Settings → Environment Variables
# Use your deployment URL, e.g. https://genex-xxx.vercel.app (no trailing slash)
NEXT_PUBLIC_SITE_URL=

# Stripe (https://dashboard.stripe.com) — subscriptions + top-ups
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=          # Signing secret from Stripe CLI or Dashboard webhook endpoint
# STRIPE_PRICE_BASIC_MONTHLY=     # Price id for Basic ($17/mo, 100 credits)
# STRIPE_PRICE_CREATOR_MONTHLY=   # Creator ($30/mo, 200 credits)
# STRIPE_PRICE_TEAM_MONTHLY=      # Team ($65/mo, 500 credits)
# STRIPE_PRICE_TOPUP_10=          # One-time $5 → 10 credits
# STRIPE_PRICE_TOPUP_50=          # $25 → 50 credits
# STRIPE_PRICE_TOPUP_100=         # $50 → 100 credits
